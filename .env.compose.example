# Copy to .env (next to docker-compose.yml) for the production stack. See docs/Deployment.md.

# Your public domain (the one HTTPS is issued for). For TP-Link DDNS this is your
# registered hostname, e.g. baby.tplinkdns.com.
DOMAIN=baby.tplinkdns.com

# Host port the app is published on (for direct LAN access / your own proxy). Default 3001.
APP_PORT=3001

# Host port Caddy's HTTPS (container 443) is published on. Default 8443 to avoid host 80/443
# being busy. Forward your router's EXTERNAL 443 -> <pi>:${HTTPS_PORT}.
HTTPS_PORT=8443

# App admin password (used as the x-admin-password header)
ADMIN_PASSWORD=change-me

# Contact email used in VAPID details
VAPID_SUBJECT=mailto:you@example.com

# Optional: pin VAPID keys so subscriptions survive a DB reset.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

TZ=Europe/Vilnius

# --- Backups ---
# Where the nightly tarballs land on the host. STRONGLY recommended: a USB drive or
# network mount, not the SD card (default: ./backups next to this file).
BACKUP_DIR=./backups
# How many nightly tarballs the Pi keeps (the Syncthing peer keeps its own longer archive).
BACKUP_KEEP=14
# Syncthing web UI port on the Pi (LAN replication of the backups folder).
SYNCTHING_GUI_PORT=8384

# --- DuckDNS only (ignore for TP-Link DDNS) ---
# Needed only if you run the optional duckdns updater:
#   docker compose --profile duckdns up -d
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
