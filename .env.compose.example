# Copy to .env (next to docker-compose.yml) for the production stack. See docs/Deployment.md.

# Your DuckDNS domain and credentials
DOMAIN=your-name.duckdns.org
DUCKDNS_SUBDOMAIN=your-name
DUCKDNS_TOKEN=your-duckdns-token

# App admin password (used as the x-admin-password header)
ADMIN_PASSWORD=change-me

# Contact email used in VAPID details
VAPID_SUBJECT=mailto:you@example.com

# Optional: pin VAPID keys so subscriptions survive a DB reset.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

TZ=Europe/Vilnius
