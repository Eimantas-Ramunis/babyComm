PORT=3000
NODE_ENV=development

APP_BASE_URL=https://your-domain.duckdns.org
ADMIN_PASSWORD=change-me

DATABASE_PATH=./data/app.sqlite

# Phase 5+ (unused in Phase 1). Verify current model names in the Gemini API docs
# before wiring these up — the names below are placeholders.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=
GEMINI_IMAGE_MODEL=

# Phase 4 (unused in Phase 1). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
